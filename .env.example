# Copy this file to .env and fill in values before running docker compose.
# Never commit .env to git.

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootsecret
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_DEVICE_TYPE_ID=1

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_JT808_DB=0
REDIS_POOL_SIZE=100

# ── Stream ───────────────────────────────────────────────────────────────────
STREAM_KEY=jt808:telemetry
STREAM_MAX_LEN=100000

# ── Protocol timings ─────────────────────────────────────────────────────────
AUTH_TIMEOUT=30s
HEARTBEAT_TIMEOUT=3m
WRITE_TIMEOUT=10s

# ── Host port overrides (change if ports are already in use) ─────────────────
JT808_TCP_PORT=7018
JT808_HTTP_PORT=9090
REDIS_EXPOSE_PORT=6379
MYSQL_EXPOSE_PORT=3306

# ── Debug ─────────────────────────────────────────────────────────────────────
APP_DEBUG=false
